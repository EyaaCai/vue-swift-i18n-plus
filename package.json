{
  "name": "vue-swift-i18n-plus",
  "displayName": "Vue Swift i18n Plus",
  "description": "An enhanced i18n automation tool for Vue/JS developers, supporting auto extraction and split file generation.",
  "publisher": "Eyaa",
  "keywords": [
    "vue",
    "vue i18n",
    "vue-i18n",
    "fast i18n",
    "i18n tool",
    "i18n",
    "developer-tool"
  ],
  "version": "0.1.1",
  "engines": {
    "vscode": "^1.37.1"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "icon": "icon.png",
  "activationEvents": [
    "*"
  ],
  "main": "dist/extension.cjs.js",
  "contributes": {
    "commands": [
      {
        "command": "vueSwiftI18nPlus.openI18nFile",
        "title": "Open File"
      },
      {
        "command": "vueSwiftI18nPlus.flatJson",
        "title": "Flat Json"
      },
      {
        "command": "vueSwiftI18nPlus.unFlatJson",
        "title": "UnFlat Json"
      },
      {
        "command": "vueSwiftI18nPlus.showI18n",
        "title": "Show I18n Translate Detail"
      },
      {
        "command": "vueSwiftI18nPlus.updateI18n",
        "title": "Update I18n Locales Json"
      },
      {
        "command": "vueSwiftI18nPlus.generateRichieRC",
        "title": "Generate scope config file"
      },
      {
        "command": "vueSwiftI18nPlus.swiftI18n",
        "title": "Swift I18n",
        "icon": {
          "light": "./icon-light.svg",
          "dark": "./icon-dark.svg"
        }
      },
      {
        "command": "vueSwiftI18nPlus.generateI18nFiles",
        "title": "Generate Split I18n Files"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Vue Swift i18n Plus",
      "properties": {
        "vueSwiftI18nPlus.defaultLocalesPath": {
          "type": "string",
          "default": "src/locales",
          "description": "Specify the 'locales' folder path for i18n files. / 指定 i18n 语言包文件夹路径 (默认 'src/locales')。"
        },
        "vueSwiftI18nPlus.doNotDisturb": {
          "type": "boolean",
          "default": false,
          "description": "Whether to suppress alert tips when executing commands. / 执行时是否不再弹出提示窗口 (默认 false)。"
        },
        "vueSwiftI18nPlus.i18nValueHover": {
          "type": "boolean",
          "default": true,
          "description": "Whether to show the translated text when hovering over an i18n key. / 鼠标悬停在 Key 上时是否显示对应的翻译详情 (默认 true)。"
        },
        "vueSwiftI18nPlus.langFile": {
          "type": "string",
          "default": "zh-cn.json",
          "description": "File name for the locales JSON. / 语言包文件名 (默认 'zh-cn.json')。"
        },
        "vueSwiftI18nPlus.puidType": {
          "type": "string",
          "default": "short",
          "description": "Generate 'long' (24-byte) or 'short' (12-byte) random IDs as keys. / 选择生成长（24位）或短（12位）随机 ID 作为 Key (默认 'short')。"
        },
        "vueSwiftI18nPlus.fileNameSubstitute": {
          "type": "string",
          "default": "components",
          "description": "Substitute folder/file name used when 'notUseFileNameAsKey' is active. / 当禁用文件名作 Key 时使用的占位符 (默认 'components')。"
        },
        "vueSwiftI18nPlus.modulePrefixFoUpdateJson": {
          "type": "string",
          "default": "",
          "description": "An optional global prefix added to generated JSON keys. / 自动提取时，为生成的 JSON 属性 Key 添加全局前缀 (默认为空)。"
        },
        "vueSwiftI18nPlus.notAlertBeforeUpdateI18n": {
          "type": "boolean",
          "default": false,
          "description": "Whether to skip the confirmation alert before extracting i18n keys. / 提取汉字前是否不再弹出确认框 (默认 false)。"
        },
        "vueSwiftI18nPlus.notUseFileNameAsKey": {
          "type": "boolean",
          "default": false,
          "description": "Whether to exclude the file name from the generated JSON key hierarchy. / 是否在 JSON 层级结构中忽略文件名 (默认 false)。"
        },
        "vueSwiftI18nPlus.parentDirLevel": {
          "type": "number",
          "default": 1,
          "description": "The number of parent directory levels to prepend to the JSON key. / 向上提取并作为 JSON Key 前缀的父目录级数 (默认 1)。"
        },
        "vueSwiftI18nPlus.useCompactPathMode": {
          "type": "boolean",
          "default": false,
          "description": "Whether to use compact path mode (merge relative path as the first level key). / 是否开启紧凑路径模式（将相对路径合并至第一层级 Key，适用于大型项目防止同名文件 Key 冲突)。"
        },
        "vueSwiftI18nPlus.useCompactModeBasePath": {
          "type": "string",
          "default": "src",
          "description": "The base path used to calculate relative paths when 'useCompactPathMode' is enabled. (Only works when 'useCompactPathMode' is true) / 当开启紧凑模式时，计算相对路径的基准目录 (仅在开启 'useCompactPathMode' 时生效，默认 'src')。"
        },
        "vueSwiftI18nPlus.useHashKeyOnly": {
          "type": "boolean",
          "default": false,
          "description": "Whether to use only the hash part as the i18n key during code replacement (ignoring full path). / 自动替换代码时，是否仅使用随机 Hash 值（忽略路径前缀，使代码保持精炼)。"
        },
        "vueSwiftI18nPlus.generateI18nFilesOutputDir": {
          "type": "string",
          "default": "src/i18n/lang/zh-cn",
          "description": "Output directory for split i18n files. / 拆分出的免配置 i18n 文件的输出目录 (默认 'src/i18n/lang/zh-cn')。"
        },
        "vueSwiftI18nPlus.generateI18nFilesExt": {
          "type": "string",
          "enum": [
            "auto",
            "js",
            "ts"
          ],
          "default": "auto",
          "description": "File extension for generated i18n files. / 生成的 i18n 文件扩展名 (默认 'auto')。"
        }
      }
    },
    "keybindings": [
      {
        "command": "vueSwiftI18nPlus.generateRichieRC",
        "key": "ctrl+alt+g",
        "mac": "ctrl+cmd+g",
        "when": "editorTextFocus"
      },
      {
        "command": "vueSwiftI18nPlus.updateI18n",
        "key": "ctrl+alt+u",
        "mac": "ctrl+cmd+u",
        "when": "editorTextFocus"
      },
      {
        "command": "vueSwiftI18nPlus.swiftI18n",
        "key": "ctrl+alt+i",
        "mac": "ctrl+cmd+i",
        "when": "editorTextFocus"
      },
      {
        "command": "vueSwiftI18nPlus.showI18n",
        "key": "ctrl+alt+o",
        "mac": "ctrl+cmd+o",
        "when": "editorTextFocus"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "when": "editorFocus && resourceLangId == json",
          "command": "vueSwiftI18nPlus.flatJson",
          "group": "1_modification@6"
        },
        {
          "when": "editorFocus && resourceLangId == json",
          "command": "vueSwiftI18nPlus.unFlatJson",
          "group": "1_modification@6"
        },
        {
          "when": "editorFocus && resourceLangId == json",
          "command": "vueSwiftI18nPlus.generateI18nFiles",
          "group": "1_modification@6"
        },
        {
          "when": "editorFocus &&  resourceLangId == javascript",
          "command": "vueSwiftI18nPlus.generateRichieRC",
          "group": "1_modification@5"
        },
        {
          "when": "editorFocus &&  resourceLangId == typescript",
          "command": "vueSwiftI18nPlus.generateRichieRC",
          "group": "1_modification@5"
        },
        {
          "when": "editorFocus &&  resourceLangId == vue",
          "command": "vueSwiftI18nPlus.generateRichieRC",
          "group": "1_modification@5"
        },
        {
          "when": "editorFocus &&  resourceLangId == javascript",
          "command": "vueSwiftI18nPlus.updateI18n",
          "group": "1_modification@6"
        },
        {
          "when": "editorFocus &&  resourceLangId == typescript",
          "command": "vueSwiftI18nPlus.updateI18n",
          "group": "1_modification@6"
        },
        {
          "when": "editorFocus &&  resourceLangId == vue",
          "command": "vueSwiftI18nPlus.updateI18n",
          "group": "1_modification@6"
        },
        {
          "when": "editorFocus &&  resourceLangId == javascript",
          "command": "vueSwiftI18nPlus.swiftI18n",
          "group": "1_modification@7"
        },
        {
          "when": "editorFocus &&  resourceLangId == typescript",
          "command": "vueSwiftI18nPlus.swiftI18n",
          "group": "1_modification@7"
        },
        {
          "when": "editorFocus &&  resourceLangId == vue",
          "command": "vueSwiftI18nPlus.swiftI18n",
          "group": "1_modification@7"
        },
        {
          "when": "editorFocus && resourceLangId == vue",
          "command": "vueSwiftI18nPlus.showI18n",
          "group": "1_modification@8"
        },
        {
          "when": "editorFocus && resourceLangId == typescript",
          "command": "vueSwiftI18nPlus.showI18n",
          "group": "1_modification@8"
        },
        {
          "when": "editorFocus && resourceLangId == javascript",
          "command": "vueSwiftI18nPlus.showI18n",
          "group": "1_modification@8"
        }
      ],
      "explorer/context": [
        {
          "command": "vueSwiftI18nPlus.generateRichieRC",
          "when": "resourceLangId == vue",
          "group": "1_modification@5"
        },
        {
          "command": "vueSwiftI18nPlus.generateI18nFiles",
          "when": "resourceLangId == json",
          "group": "1_modification@6"
        },
        {
          "command": "vueSwiftI18nPlus.generateRichieRC",
          "when": "resourceLangId == typescript",
          "group": "1_modification@5"
        },
        {
          "command": "vueSwiftI18nPlus.generateRichieRC",
          "when": "resourceLangId == javascript",
          "group": "1_modification@5"
        },
        {
          "command": "vueSwiftI18nPlus.updateI18n",
          "when": "resourceLangId == vue",
          "group": "1_modification@6"
        },
        {
          "command": "vueSwiftI18nPlus.updateI18n",
          "when": "resourceLangId == typescript",
          "group": "1_modification@6"
        },
        {
          "command": "vueSwiftI18nPlus.updateI18n",
          "when": "resourceLangId == javascript",
          "group": "1_modification@6"
        },
        {
          "command": "vueSwiftI18nPlus.swiftI18n",
          "when": "resourceLangId == vue",
          "group": "1_modification@7"
        },
        {
          "command": "vueSwiftI18nPlus.swiftI18n",
          "when": "resourceLangId == typescript",
          "group": "1_modification@7"
        },
        {
          "command": "vueSwiftI18nPlus.swiftI18n",
          "when": "resourceLangId == javascript",
          "group": "1_modification@7"
        },
        {
          "command": "vueSwiftI18nPlus.showI18n",
          "when": "resourceLangId == vue",
          "group": "1_modification@8"
        },
        {
          "command": "vueSwiftI18nPlus.showI18n",
          "when": "resourceLangId == typescript",
          "group": "1_modification@8"
        },
        {
          "command": "vueSwiftI18nPlus.showI18n",
          "when": "resourceLangId == javascript",
          "group": "1_modification@8"
        }
      ]
    },
    "snippets": [
      {
        "language": "javascript",
        "path": "./snippets/tt.json"
      },
      {
        "language": "typescript",
        "path": "./snippets/tt.json"
      },
      {
        "language": "html",
        "path": "./snippets/tt.json"
      },
      {
        "language": "html",
        "path": "./snippets/tt.json"
      },
      {
        "language": "vue-html",
        "path": "./snippets/tt.json"
      },
      {
        "language": "html",
        "path": "./snippets/tt.json"
      },
      {
        "language": "vue",
        "path": "./snippets/tt.json"
      },
      {
        "language": "jade",
        "path": "./snippets/tt.json"
      }
    ]
  },
  "scripts": {
    "test": "node ./test/runTest.js",
    "docs:dev": "vuepress dev docs",
    "docs:build": "vuepress build docs --dest=/www/wwwroot/vueSwiftI18nPlus.richieyu.top/dist",
    "vscode:prepublish": "webpack --mode production",
    "dev": "webpack --mode development",
    "dev:w": "webpack --mode development --watch"
  },
  "devDependencies": {
    "@babel/core": "^7.10.2",
    "@types/glob": "^7.1.1",
    "@types/mocha": "^5.2.6",
    "@types/node": "^10.14.14",
    "@types/vscode": "^1.37.0",
    "eslint": "^5.13.0",
    "glob": "^7.1.4",
    "mocha": "^6.2.0",
    "terser-webpack-plugin": "^3.0.2",
    "typescript": "^3.3.1",
    "vscode-test": "^1.1.0",
    "vuepress": "^1.5.2",
    "webpack": "^4.43.0",
    "webpack-cli": "^3.3.11"
  },
  "dependencies": {
    "flat": "^4.1.0",
    "json-to-ast": "^2.1.0",
    "mkdirp": "^0.5.1",
    "puid": "^1.0.7",
    "safe-eval": "^0.4.1",
    "sort-json": "^2.0.0",
    "sort-package-json": "^1.40.0",
    "unflatten": "^1.0.4",
    "validator": "^12.1.0"
  },
  "bugs": {
    "url": "https://github.com/EyaaCai/vue-swift-i18n-plus/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/EyaaCai/vue-swift-i18n-plus.git"
  },
  "homepage": "https://github.com/EyaaCai/vue-swift-i18n-plus/blob/master/README.md"
}
